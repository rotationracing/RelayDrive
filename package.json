{
  "name": "relaydrive",
  "version": "0.0.6",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tauri": "tauri",
    "tauri:dev": "dotenv -e .env -- cross-env NEXT_PUBLIC_DEEP_LINK_PROTOCOL=relaydrive-dev tauri dev -c src-tauri/tauri.dev.json",
    "tauri:build": "dotenv -e .env -- tauri build",
    "protocol:dev": "powershell -ExecutionPolicy Bypass -File scripts/register-dev-protocol.ps1",
    "i18n:push": "npx @crowdin/cli upload sources",
    "i18n:pull": "npx @crowdin/cli download"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.84.1",
    "@tauri-apps/api": "^2.7.0",
    "@tauri-apps/plugin-deep-link": "^2.4.3",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-shell": "2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.2",
    "geist": "^1.5.1",
    "lucide-react": "^0.548.0",
    "motion": "^12.23.16",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
